<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>mediasync</title>
    <link rel="stylesheet" href="/static/main.css">
</head>
<body>
    <h1>mediasync</h1>
    <form method="post" action="/host">
        <label>nickname: <input name="nickname" minlength="{{MIN_NICKNAME_LENGTH}}" maxlength="{{MAX_NICKNAME_LENGTH}}" required></label><br>
        <label>video url: <input name="video_url" type="url" required></label><br>
        <input type="submit" value="host room">
    </form><br>
    <form method="get" action="/room">
        <label>nickname: <input name="nickname" minlength="{{MIN_NICKNAME_LENGTH}}" maxlength="{{MAX_NICKNAME_LENGTH}}" required></label><br>
        <label>room id: <input name="id" required></label><br>
        <input type="submit" value="join room">
    </form>
</body>
</html>
